@{
    Layout = "_Layout";
}

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/assistente.css" asp-append-version="true" />
</head>
<style>
    .assistant-profile-image {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        flex-shrink: 0;
        border: 2px solid #e1e5e9;
        background: #fff;
        margin-right: 12px;
    }

    .chat-message.assistant {
        display: flex;
        align-items: flex-start;
        gap: 12px;
    }

    .hidden {
        display: none !important;
    }

    .assistant-profile-image {
        width: 40px;
        height: 40px;
        border-radius: 50%;
    }</style>

<div class="page-wrapper">
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="sidebar-brand">
                <img src="@Url.Content("~/img/favicon-fluently.svg")" class="sidebar-brand-icon" alt="Fluently" />
                <span class="sidebar-brand-name">Fluently</span>
            </div>
            <p class="sidebar-tagline">Seu professor de inglês com IA</p>
        </div>
        <div class="sidebar-content">
            <ul id="assistantList">
                <li onclick="selectAssistant('Nível Básico', this)">
                    <img src="@Url.Content("~/img/avatar-luna.svg")" class="sidebar-avatar" alt="Luna" />
                    <div class="sidebar-teacher-info">
                        <span class="sidebar-teacher-name">Luna</span>
                        <span class="sidebar-teacher-level">Nível Básico</span>
                    </div>
                </li>
                <li onclick="selectAssistant('Nível Intermediário', this)">
                    <img src="@Url.Content("~/img/avatar-alex.svg")" class="sidebar-avatar" alt="Alex" />
                    <div class="sidebar-teacher-info">
                        <span class="sidebar-teacher-name">Alex</span>
                        <span class="sidebar-teacher-level">Nível Intermediário</span>
                    </div>
                </li>
                <li onclick="selectAssistant('Nível Avançado', this)">
                    <img src="@Url.Content("~/img/avatar-jordan.svg")" class="sidebar-avatar" alt="Jordan" />
                    <div class="sidebar-teacher-info">
                        <span class="sidebar-teacher-name">Jordan</span>
                        <span class="sidebar-teacher-level">Nível Avançado</span>
                    </div>
                </li>
            </ul>
        </div>
        <div class="sidebar-footer">
            <form id="logoutForm" action="@Url.Action("Logout", "Login")" method="post">
                <button type="submit" class="sidebar-logout-btn">
                    <i class="fas fa-sign-out-alt"></i> Sair
                </button>
            </form>
        </div>
    </div>
    <div class="chat-container">
        <div class="chat-header">
            <img id="headerAvatar" src="@Url.Content("~/img/avatar-luna.svg")" class="header-avatar" alt="Professor" />
            <div class="chat-title-wrapper">
                <h2 id="selectedAssistantTitle">Luna</h2>
                <p id="selectedAssistantSubtitle" class="chat-subtitle">Professora de Inglês · Nível Básico</p>
            </div>
        </div>

        <div class="chat-messages" id="chatMessages">
            <div class="chat-message assistant loading loading-message" style="display: none;">
                Carregando...
            </div>
        </div>
        <div class="chat-input-container">
            <textarea id="userMessageInput" placeholder="Digite uma mensagem..." class="chat-input"></textarea>
            <button id="sendMessageButton" class="chat-button">Enviar</button>
        </div>
    </div>
</div>
<div class="loading-overlay" id="loadingOverlay" style="display: none;">
    <div class="loading-container">
        <div class="loading-spinner"></div>
        <p class="loading-text">
            Carregando Professor<span class="loading-dots"></span>
        </p>
    </div>
</div>


<div id="errorModal" class="modal" style="display: none;">
    <div class="modal-content">
        <span class="close" id="closeErrorModal">&times;</span>
        <p id="errorMessageContent">Mensagem de erro será exibida aqui.</p>
    </div>
</div>

<script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
<script>
    const buscarChatAssistenteUrl = '@Url.Action("BuscarChat", "Teacher")';
    const chatAssistenteUrl = '@Url.Action("Chat", "Teacher")';
    const streamChatUrl = '/ChatProfessorStream';
    let currentAssistant = null;
</script>

<script src="~/js/assistente.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<script src="https://cdn.jsdelivr.net/npm/dompurify@3.0.5/dist/purify.min.js"></script>

